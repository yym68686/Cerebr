{
  "schemaVersion": 2,
  "id": "local.explain-selection",
  "version": "1.0.0",
  "kind": "script",
  "scope": "page",
  "displayName": "Explain Selection",
  "description": "Show a local developer action next to selected text and send an explanation prompt into Cerebr.",
