{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cerebr.dev/schemas/plugin.schema.json",
  "title": "Cerebr Plugin Package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "version",
    "kind",
    "scope",
    "displayName",
    "description"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": ["builtin", "declarative", "script"]
    },
    "scope": {
      "type": "string",
      "enum": ["page", "shell", "prompt"]
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "defaultEnabled": {
      "type": "boolean"
    },
    "publisher": {
      "type": "string"
    },
    "homepage": {
      "type": "string"
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requiresExtension": {
      "type": "boolean"
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "versionRange": {
          "type": "string"
        }
      }
    },
    "declarative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["prompt_fragment"]
        },
        "placement": {
          "type": "string",
          "enum": ["system.prepend", "system.append"]
        },
        "content": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "prompt_fragment"
              }
            }
          },
          "then": {
            "required": ["placement", "content"]
          }
        }
      ]
    },
    "script": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entry"],
      "properties": {
        "entry": {
          "type": "string",
          "minLength": 1
        },
        "exportName": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "declarative"
          }
        }
      },
      "then": {
        "required": ["declarative"]
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "script"
          }
        }
      },
      "then": {
        "required": ["script"],
        "properties": {
          "scope": {
            "enum": ["page", "shell"]
          }
        }
      }
    }
  ]
}
